{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist-api",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "./backend/src/*": ["./backend/src/*"]
    }
  },
  "include": ["api/**/*.ts", "backend/src/**/*.ts"]
}
